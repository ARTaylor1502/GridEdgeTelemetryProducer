@inherits LayoutComponentBase
@implements IDisposable
@using GridEdge.Telemetry.Infrastructure.Configuration;
@inject PersistentComponentState ApplicationState
@inject IConfiguration Config

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private PersistingComponentStateSubscription _subscription;

    protected override void OnInitialized()
    {
        _subscription = ApplicationState.RegisterOnPersisting(() =>
        {
            var settings = new ApiSettings {
                ExternalBaseUrl = Config["ApiSettings:ExternalBaseUrl"] ?? "http://localhost:5050"
            };
            ApplicationState.PersistAsJson("ApiSettings", settings);
            return Task.CompletedTask;
        });
    }

    void IDisposable.Dispose() => _subscription.Dispose();
}